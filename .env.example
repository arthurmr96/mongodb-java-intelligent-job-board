# ── MongoDB Atlas ───────────────────────────────────────────────────────────
# Your Atlas cluster connection string.
# Get it from: Atlas UI → Connect → Drivers → Copy connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# The database to use (created automatically on first write)
MONGODB_DATABASE=jobmatching

# ── Atlas Embedding and Reranking API ───────────────────────────────────────
# Your Atlas API key for VoyageAI embeddings.
# Get it from: Atlas UI → Access Manager → API Keys
VOYAGE_API_KEY=your_atlas_api_key_here

# The VoyageAI model to use for embeddings (1024 dimensions)
VOYAGE_MODEL=voyage-4-large

# The Atlas embedding endpoint (do not change unless using a different region)
VOYAGE_API_URL=https://ai.mongodb.com/v1/embeddings

# ── LLM API for structured field extraction ─────────────────────────────────
# Used by CvExtractorService and JobExtractorService to parse PDF text.
# Default: OpenAI-compatible (gpt-4o-mini). Replace with any compatible endpoint.
LLM_API_KEY=your_openai_api_key_here
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_MODEL=gpt-4o-mini
